PORT=5050

# MongoDB connection string (required for the backend to work)
# Local: mongodb://localhost:27017/samvad
# Cloud (MongoDB Atlas): mongodb+srv://<user>:<password>@cluster.mongodb.net/samvad
MONGODB_URI=mongodb://localhost:27017/samvad

# JWT secret for auth tokens (required in production)
JWT_SECRET=your_secret_key_here

# Optional: LibreTranslate API key for better translation
# Without this, MyMemory free API is used (no key needed)
# LIBRETRANSLATE_API_KEY=

# Optional: AI API keys for auto-categorization (uses keyword fallback if both missing)
# OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=
# Google Gemini (free tier): https://aistudio.google.com/apikey
# GEMINI_API_KEY=
